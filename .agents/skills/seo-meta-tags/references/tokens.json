{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SEO Meta Tag Placeholder Tokens",
  "description": "Canonical registry of all placeholder tokens used in the meta-tag-boilerplate templates. When adding a new token, add it here first.",
  "tokens": [
    {
      "name": "PAGE_TITLE",
      "description": "Page title displayed in browser tab and search results",
      "constraints": "Max 60 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "PAGE_DESCRIPTION",
      "description": "Meta description for search engine results",
      "constraints": "150-160 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "PAGE_URL",
      "description": "Absolute URL of the current page",
      "constraints": "Must start with https://",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "CANONICAL_URL",
      "description": "Canonical URL for the page (usually same as PAGE_URL)",
      "constraints": "Must start with https://",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "KEYWORDS",
      "description": "Comma-separated keywords for the page",
      "constraints": "5-10 terms max",
      "required": false,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "AUTHOR_NAME",
      "description": "Content author full name",
      "constraints": "Plain text, no HTML",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "AUTHOR_URL",
      "description": "Author's website URL",
      "constraints": "Must start with https://",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "SITE_NAME",
      "description": "Brand or site name",
      "constraints": "Plain text",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "THEME_COLOR",
      "description": "Default theme color (hex code)",
      "constraints": "Valid hex color (e.g., #ffffff)",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "THEME_COLOR_LIGHT",
      "description": "Theme color for light color scheme",
      "constraints": "Valid hex color",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "THEME_COLOR_DARK",
      "description": "Theme color for dark color scheme",
      "constraints": "Valid hex color",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "OG_TITLE",
      "description": "Open Graph title (can differ from page title for social context)",
      "constraints": "Max 60 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "OG_DESCRIPTION",
      "description": "Open Graph description",
      "constraints": "Max 200 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "OG_IMAGE_URL",
      "description": "Open Graph image URL",
      "constraints": "Absolute URL, 1200x630px, JPG or PNG, under 1MB",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "OG_IMAGE_ALT",
      "description": "Alt text for the Open Graph image",
      "constraints": "Descriptive text, required when image is present",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "TWITTER_TITLE",
      "description": "Twitter Card title",
      "constraints": "Max 70 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "TWITTER_DESCRIPTION",
      "description": "Twitter Card description",
      "constraints": "Max 200 characters",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "TWITTER_IMAGE_URL",
      "description": "Twitter Card image URL",
      "constraints": "Absolute URL, same spec as OG image",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "TWITTER_IMAGE_ALT",
      "description": "Alt text for the Twitter Card image",
      "constraints": "Required when image is present",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "TWITTER_HANDLE",
      "description": "Organization's Twitter handle",
      "constraints": "Must start with @",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "TWITTER_CREATOR_HANDLE",
      "description": "Content creator's Twitter handle",
      "constraints": "Must start with @",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "SCHEMA_TYPE",
      "description": "JSON-LD @type value",
      "constraints": "Valid Schema.org type (e.g., WebSite, Article, Organization)",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "SCHEMA_IMAGE_URL",
      "description": "Image URL for JSON-LD structured data",
      "constraints": "Absolute URL",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "PUBLISHER_NAME",
      "description": "Publisher organization name",
      "constraints": "Plain text",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html", "nextjs/metadata.ts"]
    },
    {
      "name": "PUBLISHER_LOGO_URL",
      "description": "Publisher organization logo URL",
      "constraints": "Absolute URL",
      "required": true,
      "usedIn": ["html/index.html", "vite/index.html"]
    },
    {
      "name": "FAVICON_32x32_URL",
      "description": "Path to 32x32 favicon PNG",
      "constraints": "Relative or absolute path",
      "required": true,
      "usedIn": ["html/index.html"]
    },
    {
      "name": "FAVICON_16x16_URL",
      "description": "Path to 16x16 favicon PNG",
      "constraints": "Relative or absolute path",
      "required": true,
      "usedIn": ["html/index.html"]
    },
    {
      "name": "APPLE_TOUCH_ICON_URL",
      "description": "Path to 180x180 Apple touch icon",
      "constraints": "Relative or absolute path",
      "required": true,
      "usedIn": ["html/index.html"]
    },
    {
      "name": "ALTERNATE_EN_URL",
      "description": "English language alternate URL",
      "constraints": "Absolute URL",
      "required": false,
      "usedIn": ["html/index.html"]
    },
    {
      "name": "ALTERNATE_DEFAULT_URL",
      "description": "Default language (x-default) alternate URL",
      "constraints": "Absolute URL",
      "required": false,
      "usedIn": ["html/index.html"]
    },
    {
      "name": "CREATOR_NAME",
      "description": "Content creator name (Next.js specific)",
      "constraints": "Plain text",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "CATEGORY",
      "description": "Site content category",
      "constraints": "Free text (e.g., technology, finance)",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "GOOGLE_VERIFICATION_CODE",
      "description": "Google Search Console verification code",
      "constraints": "Use environment variables, never hardcode in public repos",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "YANDEX_VERIFICATION_CODE",
      "description": "Yandex Webmaster verification code",
      "constraints": "Use environment variables, never hardcode in public repos",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "FACEBOOK_VERIFICATION_CODE",
      "description": "Facebook domain verification code",
      "constraints": "Use environment variables, never hardcode in public repos",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "EN_URL",
      "description": "English alternate URL for Next.js alternates.languages",
      "constraints": "Absolute URL",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "ES_URL",
      "description": "Spanish alternate URL for Next.js alternates.languages",
      "constraints": "Absolute URL",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "KEYWORD_1",
      "description": "First keyword (Next.js array format)",
      "constraints": "Plain text",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "KEYWORD_2",
      "description": "Second keyword (Next.js array format)",
      "constraints": "Plain text",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    },
    {
      "name": "KEYWORD_3",
      "description": "Third keyword (Next.js array format)",
      "constraints": "Plain text",
      "required": false,
      "usedIn": ["nextjs/metadata.ts"]
    }
  ]
}
